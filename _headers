/*
  # Clickjacking bescherming
  X-Frame-Options: DENY

  # Voorkomt MIME-type sniffing
  X-Content-Type-Options: nosniff

  # XSS bescherming (legacy browsers)
  X-XSS-Protection: 1; mode=block

  # Beperkt referrer informatie bij externe links
  Referrer-Policy: strict-origin-when-cross-origin

  # Schakelt onnodige browser features uit
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()

  # HSTS — dwingt HTTPS af voor 1 jaar (activeer pas als domein + SSL actief is)
  # Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

  # Content Security Policy
  # Aangepast aan: eigen assets + Calendly embed + Netlify Forms
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://assets.calendly.com; style-src 'self' 'unsafe-inline' https://assets.calendly.com; img-src 'self' data: https://assets.calendly.com; frame-src https://calendly.com; connect-src 'self' https://calendly.com; font-src 'self'; form-action 'self' https://api.netlify.com; base-uri 'self'; object-src 'none'; upgrade-insecure-requests

# Cache headers voor statische assets
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Geen caching voor HTML pagina's zelf
/*.html
  Cache-Control: no-cache, no-store, must-revalidate

/
  Cache-Control: no-cache, no-store, must-revalidate
